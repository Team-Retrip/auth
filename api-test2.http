    client.test("탈퇴 후 토큰 재발급 차단", function() {
        client.assert(response.status === 401 || response.status === 404, "탈퇴한 회원은 토큰 재발급 불가해야 함");
    });
    client.log("✅ 탈퇴 후 토큰 재발급 차단 확인");
%}

